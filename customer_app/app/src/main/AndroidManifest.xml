<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.mywasalha">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="وصلها في السريع"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <activity
            android:name=".screens.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".screens.MainActivity" android:exported="false" />
        <activity android:name=".screens.RestaurantsActivity" android:exported="false" />
        <activity android:name=".screens.MenuActivity" android:exported="false" />
        <activity android:name=".screens.CartActivity" android:exported="false" />
        <activity android:name=".screens.CheckoutActivity" android:exported="false" />
        <activity android:name=".screens.OrderTrackingActivity" android:exported="false" />

    </application>

</manifest>
