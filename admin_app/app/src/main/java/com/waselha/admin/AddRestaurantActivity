package com.waselha.admin

import android.os.Bundle
import android.widget.Button
import android.widget.EditText
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import com.google.firebase.firestore.FirebaseFirestore

class AddRestaurantActivity : AppCompatActivity() {

    private lateinit var db: FirebaseFirestore

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_add_restaurant)

        db = FirebaseFirestore.getInstance()

        val etRestaurantName = findViewById<EditText>(R.id.etRestaurantName)
        val etOwnerName = findViewById<EditText>(R.id.etOwnerName)
        val etPhone = findViewById<EditText>(R.id.etPhone)
        val etEmail = findViewById<EditText>(R.id.etEmail)
        val etCity = findViewById<EditText>(R.id.etCity)
        val etAddress = findViewById<EditText>(R.id.etAddress)

        val btnSave = findViewById<Button>(R.id.btnSaveRestaurant)

        btnSave.setOnClickListener {

            val restaurantName = etRestaurantName.text.toString().trim()
            val ownerName = etOwnerName.text.toString().trim()
            val phone = etPhone.text.toString().trim()
            val email = etEmail.text.toString().trim()
            val city = etCity.text.toString().trim()
            val address = etAddress.text.toString().trim()

            if (restaurantName.isEmpty()) {
                etRestaurantName.error = "أدخل اسم المطعم"
                etRestaurantName.requestFocus()
                return@setOnClickListener
            }

            if (ownerName.isEmpty()) {
                etOwnerName.error = "أدخل اسم المالك"
                etOwnerName.requestFocus()
                return@setOnClickListener
            }

            if (phone.isEmpty()) {
                etPhone.error = "أدخل رقم الهاتف"
                etPhone.requestFocus()
                return@setOnClickListener
            }

            if (email.isEmpty()) {
                etEmail.error = "أدخل البريد الإلكتروني"
                etEmail.requestFocus()
                return@setOnClickListener
            }

            if (city.isEmpty()) {
                etCity.error = "أدخل المدينة"
                etCity.requestFocus()
                return@setOnClickListener
            }

            if (address.isEmpty()) {
                etAddress.error = "أدخل العنوان"
                etAddress.requestFocus()
                return@setOnClickListener
            }

            val restaurant = hashMapOf(
                "restaurantName" to restaurantName,
                "ownerName" to ownerName,
                "phone" to phone,
                "email" to email,
                "city" to city,
                "address" to address,
                "active" to true
            )

            db.collection("restaurants")
                .add(restaurant)
                .addOnSuccessListener {
                    Toast.makeText(
                        this,
                        "تمت إضافة المطعم بنجاح",
                        Toast.LENGTH_SHORT
                    ).show()

                    finish()
                }
                .addOnFailureListener {
                    Toast.makeText(
                        this,
                        "حدث خطأ أثناء إضافة المطعم",
                        Toast.LENGTH_SHORT
                    ).show()
                }
        }
    }
}
